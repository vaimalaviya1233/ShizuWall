<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- GitHub icon moved to the left of the app title -->
    <ImageView
        android:id="@+id/githubIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:contentDescription="@string/github_button_desc"
        android:src="@drawable/ic_github"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/appTitle"
        app:tint="?attr/colorPrimary" />

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="?attr/colorPrimary"
        android:textSize="24dp"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_marginStart="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toEndOf="@id/githubIcon"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/firewallProgress"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:indeterminate="true"
        android:paddingEnd="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/firewallLabel"

        app:layout_constraintTop_toTopOf="@id/appTitle"
        app:layout_constraintBottom_toBottomOf="@id/appTitle" />
    <TextView
        android:id="@+id/firewallLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enable_firewall"
        android:textSize="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toStartOf="@id/firewallToggle"
        app:layout_constraintTop_toTopOf="@id/appTitle"
        app:layout_constraintBottom_toBottomOf="@id/appTitle" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/firewallToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        app:thumbIcon="@drawable/check_24px"
        app:thumbIconTint="@color/switch_thumb_icon_tint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/appTitle"
        app:layout_constraintBottom_toBottomOf="@id/appTitle" />

    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/search_box_outline"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@null"
            android:queryHint="@string/search_app"
            android:iconifiedByDefault="false"
            app:iconifiedByDefault="false"
            app:queryBackground="@null" />

        <ImageButton
            android:id="@+id/sortButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_sort"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/sort"
            android:scaleType="center"
            android:padding="13dp"
            app:tint="?attr/colorPrimary" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@string/settings"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="center"
            android:padding="13dp"
            android:layout_marginEnd="4dp"
            app:tint="?attr/colorPrimary" />

    </LinearLayout>

    <!-- Right-side controls: scroll-to-top chip + selected count badge -->
    <LinearLayout
        android:id="@+id/rightBarControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchContainer"
        app:layout_constraintBottom_toBottomOf="@id/categoryContainer">

        <ImageView
            android:id="@+id/scrollTopButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/arrow_upward_24px"
            android:background="@drawable/selected_count_badge"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/scroll_to_top"
            app:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/selectedCountText"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="@string/selected_count_zero"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:background="@drawable/selected_count_badge"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/categoryContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:paddingLeft="0dp"
        android:paddingRight="0dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightBarControls"
        app:layout_constraintTop_toBottomOf="@id/searchContainer">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_favorites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_favorites" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_selected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_selected" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_unselected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_unselected" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_user" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_system"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_system" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintTop_toBottomOf="@id/categoryContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_app" />

    <LinearLayout
        android:id="@+id/appListLoadingContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerView"
        app:layout_constraintBottom_toBottomOf="@id/recyclerView"
        app:layout_constraintStart_toStartOf="@id/recyclerView"
        app:layout_constraintEnd_toEndOf="@id/recyclerView">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminate="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/loading_apps"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>